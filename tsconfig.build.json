{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": false,
        "noEmit": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "types": [
            "node"
        ]
    },
    "exclude": [
        ".cache/**",
        "coverage/**",
        "dist/**",
        "node_modules/**",
        "test/**",
        "vitest.config.ts"
    ],
    "extends": "./tsconfig.json",
    "include": [
        "src/**/*.ts"
    ]
}
