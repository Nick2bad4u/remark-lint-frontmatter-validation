{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "remark-lint-frontmatter-validation",
    "version": "1.0.0",
    "private": false,
    "description": "Remark lint rule and CLI for validating Markdown frontmatter against JSON Schema.",
    "keywords": [
        "ajv",
        "frontmatter",
        "json-schema",
        "lint",
        "markdown",
        "mdx",
        "remark",
        "remark-lint",
        "remark-plugin",
        "toml",
        "validation",
        "yaml"
    ],
    "homepage": "https://github.com/Nick2bad4u/remark-lint-frontmatter-validation#readme",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/remark-lint-frontmatter-validation/issues",
        "email": "20943337+Nick2bad4u@users.noreply.github.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/remark-lint-frontmatter-validation.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://github.com/Nick2bad4u)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/plugin.d.ts",
            "import": "./dist/plugin.js",
            "require": null
        },
        "./cli": {
            "types": "./dist/cli.d.ts",
            "import": "./dist/cli.js",
            "require": null
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.js",
            "require": null
        },
        "./validate": {
            "types": "./dist/validate.d.ts",
            "import": "./dist/validate.js",
            "require": null
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/plugin.js",
    "types": "./dist/plugin.d.ts",
    "bin": {
        "remark-lint-frontmatter-validation": "./dist/cli.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "changelog:generate": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/remark-lint-frontmatter-validation --output CHANGELOG.md",
        "changelog:preview": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/remark-lint-frontmatter-validation --unreleased",
        "changelog:release-notes": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/remark-lint-frontmatter-validation --current",
        "clean:dist": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\"",
        "coverage": "npm run build && vitest run --coverage",
        "lint": "eslint . --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:all": "npm run lint && npm run typecheck && npm run test && npm run lint:remark && npm run lint:prettier && npm run lint:package && npm run lint:gitleaks && npm run lint:yamllint && npm run lint:secretlint && npm run lint:yaml",
        "lint:gitleaks": "gitleaks dir --config .gitleaks.toml .",
        "lint:jscpd": "jscpd --config node_modules/jscpd-config-nick2bad4u/jscpd.json",
        "lint:lychee": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml .",
        "lint:lychee:smoke": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml --dump-inputs README.md",
        "lint:package": "npm run lint:package-json && npm run lint:package-check",
        "lint:package-check": "npm pack --dry-run && publint && attw --pack . --profile esm-only",
        "lint:package-json": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:prettier": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "lint:prettier:fix": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "lint:remark": "remark . --frail --ignore-path .remarkignore",
        "lint:remark:fix": "remark . --ignore-path .remarkignore --output",
        "lint:secretlint": "secretlint --secretlintrc .secretlintrc.cjs .",
        "lint:yaml": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache \"**/*.{yml,yaml}\"",
        "lint:yamllint": "yamllint -c .yamllint .",
        "prepack": "npm run build",
        "release:check": "npm run release:verify",
        "release:verify": "npm run build && npm run lint:all && npm run coverage && npm run lint:package-check",
        "test": "npm run build && vitest run",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "update-actions": "npx actions-up --yes --style sha",
        "update-deps": "ncu --configFileName .ncurc.json --configFilePath node_modules/ncu-config-nick2bad4u && npm update --force && npm install --force"
    },
    "overrides": {
        "esbuild": "0.28.1"
    },
    "dependencies": {
        "@apidevtools/json-schema-ref-parser": "^15.5.0",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "picomatch": "^4.0.5",
        "smol-toml": "^1.7.0",
        "tinyglobby": "^0.2.17",
        "ts-extras": "^1.2.0",
        "type-fest": "^5.8.0",
        "unified": "^11.0.5",
        "unified-lint-rule": "^3.0.1",
        "vfile": "^6.0.3",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.5",
        "@microsoft/tsdoc-config": "^0.18.1",
        "@types/mdast": "^4.0.4",
        "@types/node": "^26.1.1",
        "@types/picomatch": "^4.0.3",
        "@vitest/coverage-v8": "^4.1.10",
        "eslint": "^10.7.0",
        "eslint-config-nick2bad4u": "^5.0.0",
        "git-cliff": "^2.13.1",
        "gitcliff-config-nick2bad4u": "^1.3.0",
        "gitleaks-config-nick2bad4u": "^1.0.4",
        "jscpd": "^5.0.12",
        "jscpd-config-nick2bad4u": "^1.1.0",
        "lychee-config-nick2bad4u": "^2.0.0",
        "ncu-config-nick2bad4u": "^0.2.0",
        "npm-check-updates": "^22.2.9",
        "npm-package-json-lint": "^10.4.1",
        "npm-package-json-lint-config-nick2bad4u": "^1.0.4",
        "picocolors": "^1.1.1",
        "prettier": "^3.9.5",
        "prettier-config-nick2bad4u": "^1.1.1",
        "publint": "^0.3.21",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.1.3",
        "remark-frontmatter": "^5.0.0",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.1.2",
        "stylelint": "^17.14.0",
        "stylelint-config-nick2bad4u": "^1.0.20",
        "tsdoc-config-nick2bad4u": "^1.0.6",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10",
        "yamllint-config-nick2bad4u": "^1.1.1"
    },
    "peerDependencies": {
        "remark": "^15.0.1"
    },
    "packageManager": "npm@12.0.1",
    "engines": {
        "node": ">=22.0.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        },
        "runtime": {
            "name": "node",
            "onFail": "error",
            "version": ">=22.0.0"
        }
    },
    "publishConfig": {
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    },
    "readme": "README.md"
}
